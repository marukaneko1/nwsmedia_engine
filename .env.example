# ============================================
# SHARED INFRASTRUCTURE
# ============================================

# Local Docker Postgres (default for development)
DATABASE_URL=postgresql+asyncpg://nwsmedia:nwsmedia@localhost:5433/nwsmedia_leads

# Supabase (uncomment and set to use cloud Postgres instead of local Docker)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_supabase_anon_key
# SUPABASE_SERVICE_KEY=your_supabase_service_role_key
# DATABASE_URL=postgresql+asyncpg://postgres.your-project:your-password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

REDIS_URL=redis://localhost:6379/0

# ============================================
# CHANNEL 1: GOOGLE MAPS + AUDIT
# ============================================

GOOGLE_PAGESPEED_API_KEY=your_key_here
GOOGLE_PLACES_API_KEY=your_key_here

# Proxies (for Maps scraping)
# Get from: brightdata.com → Residential Proxies → Access parameters
# Replace USERNAME and PASSWORD with yours, e.g.:
#   http://brd-customer-hl_abc123-zone-residential:xyz789@brd.superproxy.io:22225
BRIGHT_DATA_PROXY_URL=

# CAPTCHA solving
CAPTCHA_API_KEY=your_2captcha_key

# Email enrichment
HUNTER_API_KEY=your_hunter_key

# Cold email outreach
INSTANTLY_API_KEY=your_instantly_key
INSTANTLY_CAMPAIGN_ID_MAPS=your_maps_campaign_id
# Optional: triage-specific campaigns for richer copy (see INSTANTLY_CAMPAIGNS.md)
# INSTANTLY_CAMPAIGN_ID_NO_WEBSITE=
# INSTANTLY_CAMPAIGN_ID_DEAD_WEBSITE=
# INSTANTLY_CAMPAIGN_ID_HAS_WEBSITE=

# ============================================
# CHANNEL 2: LLC FILINGS + DIRECT MAIL
# ============================================

COBALT_API_KEY=your_cobalt_key
SNOV_API_KEY=your_snov_key
LOB_API_KEY=your_lob_key
LOB_API_KEY_TEST=your_lob_test_key
INSTANTLY_CAMPAIGN_ID_LLC=your_llc_campaign_id

# ============================================
# GMAIL SENDER ACCOUNTS (Dashboard email)
# ============================================
# Primary account (required)
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password
GMAIL_DISPLAY_NAME="NWS MEDIA"

# Additional sender accounts (optional, up to 10)
# GMAIL_USER_2=second_email@gmail.com
# GMAIL_APP_PASSWORD_2=second_app_password
# GMAIL_DISPLAY_NAME_2="NWS Media Alt"

# GMAIL_USER_3=third_email@gmail.com
# GMAIL_APP_PASSWORD_3=third_app_password
# GMAIL_DISPLAY_NAME_3="Another Brand"

# ============================================
# SENDER IDENTITY (Both Channels)
# ============================================

SENDER_NAME="Your Name"
SENDER_TITLE="Founder"
SENDER_PHONE="+1 (555) 000-0000"
SENDER_COMPANY="NWS Media"

RETURN_ADDRESS_LINE1="123 Your Street"
RETURN_ADDRESS_CITY="Your City"
RETURN_ADDRESS_STATE="FL"
RETURN_ADDRESS_ZIP="33101"
